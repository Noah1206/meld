{
  "name": "@figma-code-bridge/agent",
  "version": "0.1.0",
  "description": "FigmaCodeBridge 로컬 에이전트 — 웹앱과 로컬 프로젝트를 WebSocket으로 연결",
  "private": true,
  "type": "module",
  "bin": {
    "figma-code-bridge": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./scanner": {
      "import": "./dist/scanner.js",
      "types": "./dist/scanner.d.ts"
    },
    "./watcher": {
      "import": "./dist/watcher.js",
      "types": "./dist/watcher.d.ts"
    },
    "./server": {
      "import": "./dist/server.js",
      "types": "./dist/server.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/scanner.ts src/watcher.ts src/server.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/scanner.ts src/watcher.ts src/server.ts --format esm --watch"
  },
  "dependencies": {
    "ws": "^8.18.0",
    "chokidar": "^4.0.3",
    "commander": "^13.1.0",
    "ignore": "^7.0.3"
  },
  "devDependencies": {
    "@figma-code-bridge/shared": "workspace:*",
    "@types/ws": "^8.5.14",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5"
  }
}

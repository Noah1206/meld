# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Session (openssl rand -base64 32)
SESSION_SECRET=

# Figma OAuth
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_REDIRECT_URI=https://meld-psi.vercel.app/api/auth/figma

# GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=https://meld-psi.vercel.app/api/auth/github

# AI Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GEMINI_API_KEY=

# Polar (Payments)
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_STARTER_PRODUCT_ID=
POLAR_PRO_PRODUCT_ID=
POLAR_UNLIMITED_PRODUCT_ID=

# App
NEXT_PUBLIC_APP_URL=https://meld-psi.vercel.app

# MCP OAuth apps (optional — set these to activate connection flows
# for each service. The /api/mcp/oauth-availability endpoint reports
# which services are live to the frontend, which decides whether to
# render a Connect button or an "OAuth 앱 필요" disabled state.)
#
# Vercel — https://vercel.com/docs/rest-api
VERCEL_CLIENT_ID=
VERCEL_CLIENT_SECRET=

# Linear — https://linear.app/settings/api/applications
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=

# Notion — https://www.notion.so/my-integrations (create Public integration)
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=

# Slack — https://api.slack.com/apps (OAuth & Permissions → Client ID/Secret)
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=

# Sentry — https://sentry.io/settings/account/api/applications/
SENTRY_CLIENT_ID=
SENTRY_CLIENT_SECRET=

# Google (Gmail, Calendar) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Canva — https://www.canva.com/developers/apps
CANVA_CLIENT_ID=
CANVA_CLIENT_SECRET=
